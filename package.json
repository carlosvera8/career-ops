{
  "name": "career-ops",
  "version": "1.0.0",
  "description": "AI-powered job search pipeline built on Claude Code",
  "scripts": {
    "doctor": "node doctor.mjs",
    "update:check": "node update-system.mjs check",
    "update": "node update-system.mjs apply",
    "rollback": "node update-system.mjs rollback",
    "liveness": "node check-liveness.mjs",
    "scan": "node scan.mjs",
    "drive:auth": "node auth-drive.mjs",
    "drive:upload": "node upload-to-drive.mjs --latest",
    "drive:upload:all": "node upload-to-drive.mjs --all",
    "drive:upload:master": "node upload-to-drive.mjs --master"
  },
  "keywords": [
    "ai",
    "job-search",
    "claude-code",
    "career",
    "automation"
  ],
